<UserControl x:Class="MetaMorpheusGUI.FamilyEvidenceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:plots="clr-namespace:GuiFunctions.ViewModels.ParallelSearchTask.Plots;assembly=GuiFunctions"
             mc:Ignorable="d" d:DesignHeight="300" d:DesignWidth="400"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             d:DataContext="{d:DesignInstance plots:FamilyEvidenceViewModel, IsDesignTimeCreatable=True}">
    <Border BorderBrush="LightGray" BorderThickness="1" Margin="5">
        <oxy:PlotView Model="{Binding ChartModel}"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch"
                      Margin="2" />
    </Border>
</UserControl>
