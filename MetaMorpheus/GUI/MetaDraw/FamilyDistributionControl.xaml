<UserControl x:Class="MetaMorpheusGUI.FamilyDistributionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:local="clr-namespace:MetaMorpheusGUI"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Border BorderBrush="LightGray" BorderThickness="1" Margin="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Rows of 2 tests per pair -->
                    <ItemsControl ItemsSource="{Binding TestRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" Margin="2">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Left.DisplayName}"
                                                       FontWeight="Bold" FontSize="12" Margin="5,3,0,0" />
                                            <StackPanel Orientation="Horizontal" Margin="5,0,0,2">
                                                <TextBlock FontSize="11" Foreground="Gray">
                                                    <Run Text="N=" /><Run Text="{Binding Left.DataPointCount}" />
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="Gray" Margin="8,0,0,0">
                                                    <Run Text="p=" /><Run Text="{Binding Left.MeanPValue, StringFormat=F4}" />
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="Gray" Margin="8,0,0,0">
                                                    <Run Text="q=" /><Run Text="{Binding Left.MeanQValue, StringFormat=F4}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <Grid Height="130" Margin="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <oxy:PlotView Grid.Column="0" Model="{Binding Left.RawPlotModel}" />
                                                <oxy:PlotView Grid.Column="1" Model="{Binding Left.PValuePlotModel}" />
                                                <oxy:PlotView Grid.Column="2" Model="{Binding Left.QValuePlotModel}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" BorderBrush="LightGray" BorderThickness="1" Margin="2">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Right.DisplayName}"
                                                       FontWeight="Bold" FontSize="12" Margin="5,3,0,0" />
                                            <StackPanel Orientation="Horizontal" Margin="5,0,0,2">
                                                <TextBlock FontSize="11" Foreground="Gray">
                                                    <Run Text="N=" /><Run Text="{Binding Right.DataPointCount}" />
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="Gray" Margin="8,0,0,0">
                                                    <Run Text="p=" /><Run Text="{Binding Right.MeanPValue, StringFormat=F4}" />
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="Gray" Margin="8,0,0,0">
                                                    <Run Text="q=" /><Run Text="{Binding Right.MeanQValue, StringFormat=F4}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <Grid Height="130" Margin="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <oxy:PlotView Grid.Column="0" Model="{Binding Right.RawPlotModel}" />
                                                <oxy:PlotView Grid.Column="1" Model="{Binding Right.PValuePlotModel}" />
                                                <oxy:PlotView Grid.Column="2" Model="{Binding Right.QValuePlotModel}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
