<UserControl x:Class="MetaMorpheusGUI.FamilyCombinationValidityControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:plots="clr-namespace:GuiFunctions.ViewModels.ParallelSearchTask.Plots;assembly=GuiFunctions"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance plots:FamilyCombinationValidityViewModel, IsDesignTimeCreatable=True}">
    <Grid Margin="5">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding SelectedFamilyName, StringFormat='Family: {0}'}" 
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,5" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Panel 1: Combined vs Best -->
                    <StackPanel Grid.Column="0" Margin="2">
                        <Border BorderBrush="LightGray" BorderThickness="1">
                            <oxy:PlotView Model="{Binding BestPlotModel}" Height="280" />
                        </Border>
                        <Border BorderBrush="LightGray" BorderThickness="1" Margin="0,3,0,0" Padding="5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Interpretation: Best (Min P)"
                                           FontWeight="Bold" FontSize="11" Margin="0,0,0,3" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Above diag — combo &gt; best (suspicious)" FontSize="10" Foreground="DarkRed" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CountAboveMin}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="On diag — combo &asymp; best (±5%)" FontSize="10" Foreground="DimGray" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CountOnMin}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Below diag — combo &lt; best (expected)" FontSize="10" Foreground="DarkGreen" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CountBelowMin}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Panel 2: Combined vs Mean -->
                    <StackPanel Grid.Column="1" Margin="2">
                        <Border BorderBrush="LightGray" BorderThickness="1">
                            <oxy:PlotView Model="{Binding MeanPlotModel}" Height="280" />
                        </Border>
                        <Border BorderBrush="LightGray" BorderThickness="1" Margin="0,3,0,0" Padding="5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Interpretation: Mean (Avg P)"
                                           FontWeight="Bold" FontSize="11" Margin="0,0,0,3" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Above diag — combo &gt; mean (amplifies)" FontSize="10" Foreground="DarkGoldenrod" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CountAboveMean}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="On diag — combo &asymp; mean (+-5%)" FontSize="10" Foreground="DimGray" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CountOnMean}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Below diag — combo &lt; mean (moderates)" FontSize="10" Foreground="DarkGreen" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CountBelowMean}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Panel 3: Combined vs Worst -->
                    <StackPanel Grid.Column="2" Margin="2">
                        <Border BorderBrush="LightGray" BorderThickness="1">
                            <oxy:PlotView Model="{Binding WorstPlotModel}" Height="280" />
                        </Border>
                        <Border BorderBrush="LightGray" BorderThickness="1" Margin="0,3,0,0" Padding="5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Interpretation: Worst (Max P)"
                                           FontWeight="Bold" FontSize="11" Margin="0,0,0,3" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Above diag — combo &gt; worst (expected)" FontSize="10" Foreground="DarkGreen" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CountAboveMax}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="On diag — combo &asymp; worst (+-5%)" FontSize="10" Foreground="DimGray" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CountOnMax}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Below diag — combo &lt; worst (impossible)" FontSize="10" Foreground="DarkRed" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CountBelowMax}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
